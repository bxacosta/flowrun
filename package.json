{
  "name": "flowrun",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "fix": "ultracite fix",
    "check": "ultracite check",
    "typecheck": "bun run typecheck:core && bun run typecheck:browser",
    "typecheck:core": "bun run --cwd ./packages/core typecheck",
    "typecheck:browser": "bun run --cwd ./packages/browser typecheck",
    "fix:core": "bun run --cwd ./packages/core fix",
    "check:core": "bun run --cwd ./packages/core check",
    "test:core": "bun run --cwd ./packages/core test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "latest",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  }
}
