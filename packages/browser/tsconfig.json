{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Module system
    "module": "NodeNext",

    // Environment
    "lib": ["ESNext"],
    "types": ["bun"],

    // Emit
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "examples"]
}
